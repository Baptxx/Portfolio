---
import Nav from "@/components/Nav";
import { ModeToggle } from "@/components/ModeToggle";
import { Button } from "@/components/ui/button";
import { ArrowLeft, Mail, BadgeCheck } from "lucide-react";
---

<div class="flex justify-center w-full min-h-screen bg-background text-foreground">
  <div class="w-full max-w-[600px] border-x border-border flex flex-col">
    
    <header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md">
      <nav class="flex items-center h-14 px-4 gap-4">
        <a href="/" class="p-2 hover:bg-accent rounded-full transition-colors">
          <ArrowLeft className="w-5 h-5" />
        </a>
        <div class="flex flex-col flex-1">
          <h1 class="font-bold text-lg leading-tight tracking-tight">Baptiste HUBERT</h1>
          <span class="text-xs text-muted-foreground font-normal">1,245 Posts</span>
        </div>
        <ModeToggle client:load />
      </nav>
    </header>

    <main>
      <div class="w-full aspect-[3/1] bg-muted overflow-hidden">
        <img 
          src="https://images.unsplash.com/photo-1557683316-973673baf926" 
          alt="Bannière" 
          class="w-full h-full object-cover"
        />
      </div>

      <div class="px-4">
        <div class="relative flex justify-between items-end">
          <div class="-mt-16 w-32 h-32 rounded-full border-4 border-background bg-muted overflow-hidden shadow-sm">
            <img 
              src="https://avatars.githubusercontent.com/u/180057806?v=4" 
              alt="Photo de profil" 
              class="w-full h-full object-cover"
            />
          </div>
          
          <div class="mb-2 flex gap-2">
            <Button variant="outline" size="icon" className="relative overflow-hidden rounded-full border-border h-9 w-9 group transition-all duration-300 hover:border-[#1d9bf0]/50">
              <Mail className="w-5 h-5 z-10 transition-all duration-300 group-hover:text-[#1d9bf0] group-hover:drop-shadow-[0_0_8px_rgba(29,155,240,0.8)]" />
              
              <div class="absolute inset-0 translate-x-[-100%] group-hover:animate-[shimmer_1.5s_infinite] bg-gradient-to-r from-transparent via-white/40 to-transparent z-0"></div>
            </Button>

            <Button className="rounded-full font-bold px-6 h-9">
              Suivre
            </Button>
          </div>
        </div>

        <div class="mt-4 pb-4">
          <div class="flex items-center gap-1">
            <h2 class="text-xl font-extrabold leading-tight">Baptiste HUBERT</h2>
            <BadgeCheck className="w-5 h-5 fill-[#1d9bf0] text-background stroke-[2.5px] animate-pulse drop-shadow-[0_0_4px_rgba(29,155,240,0.6)]" />
          </div>
          <p class="text-muted-foreground text-[15px]">@baptistehbt</p>
          
          <div class="mt-3 text-[15px] leading-normal">
            Développeur Web & Designer. Passionné par la création d'interfaces propres et intuitives. 🚀
          </div>
        </div>
      </div>

      <nav class="flex w-full border-b border-border">
        <a href="#" class="flex-1 py-4 text-center hover:bg-accent/50 transition-colors relative group">
          <span class="font-bold text-sm">Posts</span>
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-14 h-1 bg-[#1d9bf0] rounded-full"></div>
        </a>
        <a href="#" class="flex-1 py-4 text-center hover:bg-accent/50 transition-colors text-muted-foreground font-bold text-sm">
          Réponses
        </a>
        <a href="#" class="flex-1 py-4 text-center hover:bg-accent/50 transition-colors text-muted-foreground font-bold text-sm">
          Projets
        </a>
      </nav>

      <div class="min-h-screen px-4 py-8 text-center text-muted-foreground italic">
        Aucun post pour le moment.
      </div>
    </main>
  </div>
</div>

<style is:global>
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
</style>